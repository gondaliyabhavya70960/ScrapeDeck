# ─────────────────────────────────────────────────────────────────────────────
# ScrapeDeck environment — copy to .env for local runs. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Where the scraper writes results.
#   google-sheets (default) → Products / PriceHistory / Runs tabs in a Google Sheet
#   local-xlsx              → data/scrapedeck.xlsx on this device (no Google account)
STORAGE_BACKEND=google-sheets

# ── Google Sheets backend (required when STORAGE_BACKEND=google-sheets) ──────────
# The service-account JSON key, base64-encoded. Generate with:
#   base64 -w0 service-account.json        (Linux)
#   base64 service-account.json | tr -d '\n'   (macOS)
# Stored base64 to avoid private_key "\n" corruption in env vars.
GOOGLE_SERVICE_ACCOUNT_KEY_B64=

# The spreadsheet ID — the long token in the Sheet URL:
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
# A default (the connected Sheet) is baked into scraper/lib/sheets.ts, so this
# only needs setting to target a DIFFERENT spreadsheet.
# Remember to SHARE the Sheet with the service-account email (Editor).
SHEET_ID=

# ── local-xlsx backend ──────────────────────────────────────────────────────────
# Directory for the local workbook + `pnpm export` device copies. Default: data
DATA_DIR=data

# ── Run controls ────────────────────────────────────────────────────────────────
# Restrict a run to one source key for a fast smoke test, e.g. ONLY=rabh
# ONLY=rabh

# ── Optional notifications (Discord or Slack incoming webhook) ───────────────────
# Set both, or neither.
# NOTIFY_WEBHOOK_URL=
# NOTIFY_WEBHOOK_KIND=discord
